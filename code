clc;
clear;
close all;

%% Step 1: Generate Synthetic Diabetes Data
n = 500;   % number of patients
features = 8; % number of predictor variables

% Generate random patient features
X = randn(n,features);

% Create a progression variable (target)
Y = 2*X(:,1) + 1.5*X(:,2) - X(:,3) + 0.5*X(:,4) + randn(n,1);

%% Step 2: Normalize Data
X = normalize(X);

%% Step 3: Split Data (80% Training, 20% Testing)
cv = cvpartition(n,'HoldOut',0.2);

Xtrain = X(training(cv),:);
Ytrain = Y(training(cv));

Xtest = X(test(cv),:);
Ytest = Y(test(cv));

%% Step 4: Train Model (Ensemble Regression)
model = fitrensemble(Xtrain,Ytrain,'Method','Bag');

%% Step 5: Prediction
Ypred = predict(model,Xtest);

%% Step 6: Evaluation
RMSE = sqrt(mean((Ytest - Ypred).^2));
MAE = mean(abs(Ytest - Ypred));
R2 = corr(Ytest,Ypred)^2;

fprintf('RMSE = %.3f\n',RMSE);
fprintf('MAE = %.3f\n',MAE);
fprintf('R2 Score = %.3f\n',R2);

%% Step 7: Plot Actual vs Predicted
figure
plot(Ytest,'b','LineWidth',2)
hold on
plot(Ypred,'r','LineWidth',2)
legend('Actual','Predicted')
title('Diabetes Progression Prediction')
xlabel('Patient Samples')
ylabel('Progression Value')
grid on

%% Step 8: Feature Importance
imp = predictorImportance(model);

figure
bar(imp)
title('Feature Importance')
xlabel('Predictor Variables')
ylabel('Importance Score')
grid on
